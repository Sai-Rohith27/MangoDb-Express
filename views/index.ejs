<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Mini WhatsApp</title>
    <link rel="stylesheet" href="/style.css">
</head>
<body>
     <% for (let ch of chats) {%> 
            <div class="chat">
                <p>from:<%=ch.from%></p>
            <div class="msg">
                <p><%=ch.msg%></p>
            </div>
            <p>Recieved by: <i><%=ch.to%></i></p>
              </div>
              <br><br>
        <%}%>
</body>
</html>